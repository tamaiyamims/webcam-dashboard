INSERT INTO Enrollments (student_id, course_id, term, grade) VALUES
(1, 101, 'Spring 2026', 'A'),
(2, 101, 'Spring 2026', 'B'),
(3, 102, 'Spring 2026', 'A-'),
(4, 103, 'Spring 2026', 'B+'),
(1, 105, 'Spring 2026', NULL),
(5, 104, 'Spring 2026', NULL),
(2, 102, 'Spring 2026', NULL);

-- ==========================
-- SUMMARY TABLE
-- ==========================

CREATE TABLE IF NOT EXISTS enrollment_summary (
    term TEXT,
    department TEXT,
    course TEXT,
    total_students INTEGER,
    avg_grade REAL,
    pass_rate REAL
);

INSERT INTO enrollment_summary VALUES
('Fall 2025', 'Math', 'Algebra', 120, 78.5, 0.86),
('Fall 2025', 'CS', 'Intro Programming', 150, 82.1, 0.91),
('Spring 2026', 'Math', 'Calculus', 100, 74.2, 0.80),
('Spring 2026', 'CS', 'Data Structures', 130, 79.6, 0.88);

-- ==========================
-- QUERIES
-- ==========================

SELECT term, SUM(total_students) AS total_enrollment
FROM enrollment_summary
GROUP BY term;

SELECT department, SUM(total_students) AS total_students
FROM enrollment_summary
GROUP BY department;

SELECT course, AVG(avg_grade) AS avg_grade
FROM enrollment_summary
GROUP BY course;</sql><current_tab id="0"/></tab_sql></sqlb_project>

('John', 'Doe', 'john.doe@university.com', 'Computer Science'),
('Jane', 'Smith', 'jane.smith@university.com', 'Mathematics'),
('Mike', 'Brown', 'mike.brown@university.com', 'Physics'),
('Anna', 'Davis', 'anna.davis@university.com', 'Chemistry');

INSERT INTO Courses (course_id, course_name, capacity, faculty_id) VALUES
(101, 'Intro to CS', 3, 1),
(102, 'Calculus I', 2, 2),
